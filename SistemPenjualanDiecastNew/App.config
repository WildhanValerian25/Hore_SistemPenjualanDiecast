<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<connectionStrings>
		<!--
            ✅ Diisi supaya Koneksi.GetConnectionString() membaca dari sini,
            bukan jatuh ke DEFAULT_CONN_STRING (yang hardcode ke laptop ini).

            Saat deploy ke laptop client (dosen/asdos):
            - Cukup edit baris connectionString di SistemPenjualanDiecastNew.exe.config
              (file ini setelah di-build/install), TANPA compile ulang.
            - Ganti "Data Source=..." sesuai alamat laptop server (nama instance
              atau IP, tergantung setup network kalian).
        -->
		<add name="DbDiecast"
             connectionString="Data Source=LAPTOP-24A5CGHI\WILDHANFIGHT;Initial Catalog=db_penjualan_diecast;User ID=app_diecast;Password=Diecast123!"
             providerName="System.Data.SqlClient" />
	</connectionStrings>

	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
	</startup>
	<runtime>
		<assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
			<dependentAssembly>
				<assemblyIdentity name="CrystalDecisions.CrystalReports.Engine" publicKeyToken="692fbea5521e1304" culture="neutral" />
				<bindingRedirect oldVersion="0.0.0.0-13.0.4000.0" newVersion="13.0.4000.0" />
			</dependentAssembly>
			<dependentAssembly>
				<assemblyIdentity name="CrystalDecisions.Shared" publicKeyToken="692fbea5521e1304" culture="neutral" />
